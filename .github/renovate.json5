{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:best-practices",
    ":pinAllExceptPeerDependencies",
    ":automergePatch",
    ":automergeDigest",
    ":automergeLinters",
    ":automergeTesters",
    "group:nextjsMonorepo",
    "group:nodeJs",
  ],
  pinDigest: { automerge: true },
  postUpdateOptions: ["pnpmDedupe"],
  packageRules: [{ matchDepTypes: ["packageManager"], automerge: true }],
}
